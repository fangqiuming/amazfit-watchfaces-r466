#!/usr/bin/env node

const fs = require('node:fs');
const path = require('node:path');
const readline = require('node:readline');
const { spawn } = require('node:child_process');

const REPO_ROOT = path.resolve(__dirname);
const README_PATH = path.join(REPO_ROOT, 'README.md');
const ARTIFACTS_ROOT = path.join(REPO_ROOT, 'artifacts', 'releases');
const PACKAGE_DIR_PATTERN = /^\d+$/;
const IGNORED_ENTRY_NAMES = new Set(['.DS_Store', 'Thumbs.db']);

function stripByteOrderMark(source) {
  return source.charCodeAt(0) === 0xfeff ? source.slice(1) : source;
}

function discoverWatchfaces() {
  const topLevelEntries = fs.readdirSync(REPO_ROOT, { withFileTypes: true });
  const watchfaces = [];

  for (const entry of topLevelEntries) {
    if (!entry.isDirectory()) {
      continue;
    }

    if (entry.name.startsWith('.')) {
      continue;
    }

    const watchfaceRoot = path.join(REPO_ROOT, entry.name);
    const packageEntries = fs.readdirSync(watchfaceRoot, { withFileTypes: true });

    for (const packageEntry of packageEntries) {
      if (!packageEntry.isDirectory() || !PACKAGE_DIR_PATTERN.test(packageEntry.name)) {
        continue;
      }

      const packageDir = path.join(watchfaceRoot, packageEntry.name);
      const appJsonPath = path.join(packageDir, 'app.json');

      if (!fs.existsSync(appJsonPath)) {
        continue;
      }

      const appJson = JSON.parse(stripByteOrderMark(fs.readFileSync(appJsonPath, 'utf8')));
      const app = appJson.app || {};
      const version = app.version || {};

      watchfaces.push({
        slug: entry.name,
        watchfaceRoot,
        packageName: packageEntry.name,
        packageDir,
        appJsonPath,
        appId: String(app.appId || packageEntry.name),
        appName: app.appName || entry.name,
        versionName: version.name || '0.0.0-r0',
        versionCode: Number(version.code || 0)
      });
    }
  }

  watchfaces.sort((left, right) => left.appName.localeCompare(right.appName));
  return watchfaces;
}

function printHelp() {
  console.log(`Usage:
  ./watchface list
  ./watchface preview [--watchface <name-or-slug>]
  ./watchface bump [--watchface <name-or-slug>]
  ./watchface bump [--watchface <name-or-slug>] --upstream-name <name> --upstream-code <code>
  ./watchface sync-readme [--watchface <name-or-slug> | --all]
  ./watchface release [--watchface <name-or-slug> | --all]

Commands:
  list       Show all discovered watchfaces.
  preview    Run "zeus preview" in the selected watchface package.
  bump       Update app.json, release notes, and README for the next release version.
  sync-readme Refresh README sections from release-notes.json.
  release    Create GitHub-ready zip artifacts from the selected watchface package.

Options:
  -w, --watchface <value>  Select by slug, app name, or app id.
  --upstream-name <value>  Start a new upstream version and reset the local revision to r1.
  --upstream-code <value>  Upstream numeric version code used to compute version.code.
  -a, --all                Release all watchfaces without prompting.
  -h, --help               Show this help message.
`);
}

function parseArgs(argv) {
  const firstArg = argv[0];
  const parsed = {
    command: !firstArg || firstArg === '-h' || firstArg === '--help' ? 'help' : firstArg,
    selector: null,
    all: false,
    help: false,
    upstreamName: null,
    upstreamCode: null
  };

  const startIndex = parsed.command === 'help' && firstArg ? 1 : 1;

  for (let index = startIndex; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === '-h' || arg === '--help') {
      parsed.help = true;
      continue;
    }

    if (arg === '-a' || arg === '--all') {
      parsed.all = true;
      continue;
    }

    if (arg === '-w' || arg === '--watchface') {
      const value = argv[index + 1];
      if (!value) {
        throw new Error('Missing value for --watchface.');
      }
      parsed.selector = value;
      index += 1;
      continue;
    }

    if (arg === '--upstream-name') {
      const value = argv[index + 1];
      if (!value) {
        throw new Error('Missing value for --upstream-name.');
      }
      parsed.upstreamName = value;
      index += 1;
      continue;
    }

    if (arg === '--upstream-code') {
      const value = argv[index + 1];
      if (!value) {
        throw new Error('Missing value for --upstream-code.');
      }
      parsed.upstreamCode = value;
      index += 1;
      continue;
    }

    if (!parsed.selector) {
      parsed.selector = arg;
      continue;
    }

    throw new Error(`Unexpected argument: ${arg}`);
  }

  return parsed;
}

function formatWatchface(watchface) {
  return `${watchface.appName} [${watchface.slug} / ${watchface.appId} / ${watchface.versionName}]`;
}

function normalize(value) {
  return String(value).trim().toLowerCase();
}

function resolveWatchface(watchfaces, selector) {
  const wanted = normalize(selector);
  const candidates = watchfaces.filter((watchface) => {
    const name = normalize(watchface.appName);
    const slug = normalize(watchface.slug);
    const appId = normalize(watchface.appId);
    const packageName = normalize(watchface.packageName);
    const slugWithPackage = normalize(`${watchface.slug}/${watchface.packageName}`);

    return (
      name === wanted ||
      slug === wanted ||
      appId === wanted ||
      packageName === wanted ||
      slugWithPackage === wanted
    );
  });

  if (candidates.length === 1) {
    return candidates[0];
  }

  if (candidates.length > 1) {
    throw new Error(`Selector "${selector}" matched multiple watchfaces. Use a more specific value.`);
  }

  throw new Error(`Could not find a watchface matching "${selector}".`);
}

function createInterface() {
  return readline.createInterface({
    input: process.stdin,
    output: process.stdout
  });
}

function question(rl, prompt) {
  return new Promise((resolve) => {
    rl.question(prompt, resolve);
  });
}

async function promptForWatchfaces(watchfaces, options = {}) {
  const { allowAll = false } = options;

  if (!process.stdin.isTTY) {
    throw new Error('Interactive selection requires a TTY. Pass --watchface or --all instead.');
  }

  const rl = createInterface();

  try {
    console.log('Available watchfaces:');
    if (allowAll) {
      console.log('  0. All watchfaces');
    }

    watchfaces.forEach((watchface, index) => {
      console.log(`  ${index + 1}. ${formatWatchface(watchface)}`);
    });

    while (true) {
      const answer = await question(
        rl,
        allowAll ? 'Select a watchface number (or 0 for all): ' : 'Select a watchface number: '
      );
      const trimmed = answer.trim();

      if (allowAll && trimmed === '0') {
        return watchfaces;
      }

      const selectedIndex = Number.parseInt(trimmed, 10);
      if (Number.isInteger(selectedIndex) && selectedIndex >= 1 && selectedIndex <= watchfaces.length) {
        return [watchfaces[selectedIndex - 1]];
      }

      console.log('Please enter a valid selection.');
    }
  } finally {
    rl.close();
  }
}

async function chooseWatchfaces(watchfaces, options = {}) {
  const { selector = null, allowAll = false, all = false } = options;

  if (all) {
    return watchfaces;
  }

  if (selector) {
    return [resolveWatchface(watchfaces, selector)];
  }

  return promptForWatchfaces(watchfaces, { allowAll });
}

function runCommand(command, args, options = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(command, args, {
      cwd: options.cwd || REPO_ROOT,
      stdio: options.stdio || 'inherit'
    });

    child.on('error', (error) => {
      reject(new Error(`Failed to start "${command}": ${error.message}`));
    });

    child.on('exit', (code) => {
      if (code === 0) {
        resolve();
        return;
      }
      reject(new Error(`"${command} ${args.join(' ')}" exited with code ${code}.`));
    });
  });
}

function ensureValidRevision(watchface) {
  const match = String(watchface.versionName).match(/-r(\d+)$/);
  if (!match) {
    throw new Error(
      `${watchface.appJsonPath} uses "${watchface.versionName}", but release expects a "-rN" suffix.`
    );
  }

  const revision = Number.parseInt(match[1], 10);
  if (!Number.isInteger(revision) || revision < 1) {
    throw new Error(`${watchface.appJsonPath} has an invalid revision in "${watchface.versionName}".`);
  }

  if (watchface.versionCode % 1000 !== revision) {
    throw new Error(
      `${watchface.appJsonPath} has version.code=${watchface.versionCode}, which does not match revision r${revision}.`
    );
  }
}

function sanitizeFileName(value) {
  return String(value)
    .trim()
    .replace(/\s+/g, '_')
    .replace(/[^A-Za-z0-9._-]/g, '');
}

function createTimestamp() {
  const now = new Date();
  const parts = [
    now.getFullYear(),
    String(now.getMonth() + 1).padStart(2, '0'),
    String(now.getDate()).padStart(2, '0'),
    String(now.getHours()).padStart(2, '0'),
    String(now.getMinutes()).padStart(2, '0'),
    String(now.getSeconds()).padStart(2, '0')
  ];

  return parts.join('');
}

function getReleaseBaseName(watchface) {
  const safeAppName = sanitizeFileName(watchface.appName) || sanitizeFileName(watchface.slug) || watchface.appId;
  return [watchface.appId, safeAppName, watchface.versionName].join('-');
}

function getReleaseOutputDir(watchface) {
  return path.join(ARTIFACTS_ROOT, watchface.slug);
}

function getSuggestedTagName(watchface) {
  return `${watchface.slug}-v${watchface.versionName}`;
}

function getSuggestedReleaseTitle(watchface) {
  return `${watchface.appName} ${watchface.versionName}`;
}

function getReleaseNotesPath(watchface) {
  return path.join(watchface.watchfaceRoot, 'release-notes.json');
}

function readJsonFile(filePath) {
  return JSON.parse(stripByteOrderMark(fs.readFileSync(filePath, 'utf8')));
}

function detectJsonIndent(source) {
  const match = source.match(/^[ \t]+(?="[^"]+":)/m);
  return match ? match[0] : '  ';
}

function writeJsonFile(filePath, data, indent) {
  fs.writeFileSync(filePath, `${JSON.stringify(data, null, indent)}\n`);
}

function parseVersionName(versionName) {
  const match = String(versionName).match(/^(.*)-r(\d+)$/);
  if (!match) {
    throw new Error(`Expected a version name with "-rN" suffix, received "${versionName}".`);
  }

  return {
    upstreamName: match[1],
    revision: Number.parseInt(match[2], 10)
  };
}

function parsePositiveInteger(value, label) {
  const parsed = Number.parseInt(String(value), 10);
  if (!Number.isInteger(parsed) || parsed < 1) {
    throw new Error(`${label} must be a positive integer.`);
  }
  return parsed;
}

function getReleaseNotesData(watchface) {
  const releaseNotesPath = getReleaseNotesPath(watchface);
  if (!fs.existsSync(releaseNotesPath)) {
    throw new Error(`Missing release notes file: ${releaseNotesPath}`);
  }

  const data = readJsonFile(releaseNotesPath);
  if (typeof data.summary !== 'string' || !data.summary.trim()) {
    throw new Error(`${releaseNotesPath} must define a non-empty "summary".`);
  }

  if (!Array.isArray(data.releases) || data.releases.length === 0) {
    throw new Error(`${releaseNotesPath} must define a non-empty "releases" array.`);
  }

  return {
    path: releaseNotesPath,
    summary: data.summary.trim(),
    releases: data.releases
  };
}

function getReleaseEntryForVersion(watchface) {
  const notes = getReleaseNotesData(watchface);
  const entry = notes.releases.find((release) => release.version === watchface.versionName);

  if (!entry) {
    throw new Error(
      `${notes.path} does not contain a release entry for version ${watchface.versionName}.`
    );
  }

  if (!Array.isArray(entry.changes) || entry.changes.length === 0) {
    throw new Error(
      `${notes.path} release entry for ${watchface.versionName} must include a non-empty "changes" array.`
    );
  }

  return {
    notesPath: notes.path,
    summary: notes.summary,
    version: entry.version,
    changes: entry.changes.map((change) => String(change).trim()).filter(Boolean)
  };
}

function createReleaseBody(watchface, releaseEntry) {
  const lines = [
    '## Summary',
    '',
    releaseEntry.summary,
    '',
    `## What's Changed in ${releaseEntry.version}`,
    ''
  ];

  for (const change of releaseEntry.changes) {
    lines.push(`- ${change}`);
  }

  lines.push('');
  lines.push('## Package Info');
  lines.push('');
  lines.push(`- App ID: \`${watchface.appId}\``);
  lines.push(`- Version: \`${watchface.versionName}\``);
  lines.push(`- Repository Path: \`${path.relative(REPO_ROOT, watchface.packageDir)}\``);

  return `${lines.join('\n')}\n`;
}

function createGitTagCommands(watchface) {
  const tag = getSuggestedTagName(watchface);
  const title = getSuggestedReleaseTitle(watchface);

  return [
    `git tag -a ${tag} -m "${title}"`,
    `git push origin ${tag}`
  ];
}

function getNextVersion(watchface, options = {}) {
  const wantsNewUpstream = options.upstreamName !== null || options.upstreamCode !== null;

  if (wantsNewUpstream) {
    if (!options.upstreamName || !options.upstreamCode) {
      throw new Error('Provide both --upstream-name and --upstream-code when starting a new upstream version.');
    }

    const upstreamCode = parsePositiveInteger(options.upstreamCode, '--upstream-code');
    return {
      versionName: `${options.upstreamName}-r1`,
      versionCode: upstreamCode * 1000 + 1,
      mode: 'new_upstream'
    };
  }

  const baselineMatch = String(watchface.versionName).match(/-r\d+$/);
  if (!baselineMatch) {
    const upstreamCode = parsePositiveInteger(watchface.versionCode, `${watchface.appJsonPath} version.code`);
    return {
      versionName: `${watchface.versionName}-r1`,
      versionCode: upstreamCode * 1000 + 1,
      mode: 'baseline_import'
    };
  }

  ensureValidRevision(watchface);

  const current = parseVersionName(watchface.versionName);
  const currentUpstreamCode = Math.floor(watchface.versionCode / 1000);
  const nextRevision = current.revision + 1;
  return {
    versionName: `${current.upstreamName}-r${nextRevision}`,
    versionCode: currentUpstreamCode * 1000 + nextRevision,
    mode: 'next_revision'
  };
}

function updateAppJsonVersion(watchface, versionInfo) {
  const source = fs.readFileSync(watchface.appJsonPath, 'utf8');
  const indent = detectJsonIndent(source);
  const appJson = JSON.parse(stripByteOrderMark(source));

  appJson.app = appJson.app || {};
  appJson.app.version = appJson.app.version || {};
  appJson.app.version.name = versionInfo.versionName;
  appJson.app.version.code = versionInfo.versionCode;

  writeJsonFile(watchface.appJsonPath, appJson, indent);

  watchface.versionName = versionInfo.versionName;
  watchface.versionCode = versionInfo.versionCode;
}

function addReleaseNotesEntry(watchface, versionName) {
  const releaseNotesPath = getReleaseNotesPath(watchface);
  const source = fs.readFileSync(releaseNotesPath, 'utf8');
  const indent = detectJsonIndent(source);
  const releaseNotes = JSON.parse(source);

  if (releaseNotes.releases.some((release) => release.version === versionName)) {
    throw new Error(`${releaseNotesPath} already contains a release entry for ${versionName}.`);
  }

  releaseNotes.releases.unshift({
    version: versionName,
    changes: [
      'TODO: describe this release.'
    ]
  });

  writeJsonFile(releaseNotesPath, releaseNotes, indent);
  return releaseNotesPath;
}

function renderReadmeVersionHistory(releases) {
  const lines = [
    '**What\'s Modified by Version:**',
    ''
  ];

  for (const release of releases) {
    lines.push(`#### \`${release.version}\``);
    lines.push('');
    for (const change of release.changes) {
      lines.push(`- ${change}`);
    }
    lines.push('');
  }

  while (lines.length > 0 && lines[lines.length - 1] === '') {
    lines.pop();
  }

  return lines;
}

function trimTrailingBlankLines(lines) {
  const trimmed = [...lines];
  while (trimmed.length > 0 && trimmed[trimmed.length - 1] === '') {
    trimmed.pop();
  }
  return trimmed;
}

function syncReadmeForWatchface(watchface) {
  const readmeLines = fs.readFileSync(README_PATH, 'utf8').split('\n');
  const repoPath = path.relative(REPO_ROOT, watchface.packageDir).replace(/\\/g, '/');
  const repoPathLineIndex = readmeLines.findIndex((line) => line.includes(`(${repoPath})`));

  if (repoPathLineIndex === -1) {
    throw new Error(`Could not find ${repoPath} in ${README_PATH}.`);
  }

  let sectionStartIndex = -1;
  for (let index = repoPathLineIndex; index >= 0; index -= 1) {
    if (readmeLines[index].startsWith('### ')) {
      sectionStartIndex = index;
      break;
    }
  }

  if (sectionStartIndex === -1) {
    throw new Error(`Could not find the README section start for ${repoPath}.`);
  }

  let sectionEndIndex = readmeLines.length;
  for (let index = sectionStartIndex + 1; index < readmeLines.length; index += 1) {
    if (readmeLines[index].startsWith('### ') || readmeLines[index].startsWith('## ')) {
      sectionEndIndex = index;
      break;
    }
  }

  const sectionLines = readmeLines.slice(sectionStartIndex, sectionEndIndex);
  const versionLineIndex = sectionLines.findIndex((line) => line.startsWith('* **Version**:'));
  if (versionLineIndex === -1) {
    throw new Error(`Could not find the version line for ${repoPath} in ${README_PATH}.`);
  }

  const modifiedLineIndex = sectionLines.findIndex((line) => line.startsWith('**What\'s Modified'));
  if (modifiedLineIndex === -1) {
    throw new Error(`Could not find the version history block for ${repoPath} in ${README_PATH}.`);
  }

  sectionLines[versionLineIndex] = `* **Version**: \`${watchface.versionName}\``;

  const releaseNotes = getReleaseNotesData(watchface);
  const versionHistoryLines = renderReadmeVersionHistory(releaseNotes.releases);
  const rebuiltSection = [
    ...trimTrailingBlankLines(sectionLines.slice(0, modifiedLineIndex)),
    '',
    ...versionHistoryLines,
    ''
  ];

  const rebuiltReadmeLines = [
    ...readmeLines.slice(0, sectionStartIndex),
    ...rebuiltSection,
    ...readmeLines.slice(sectionEndIndex)
  ];

  const rebuiltReadme = `${trimTrailingBlankLines(rebuiltReadmeLines).join('\n')}\n`;

  fs.writeFileSync(README_PATH, rebuiltReadme);
}

function collectPackageFiles(packageDir) {
  const packageRoot = path.dirname(packageDir);
  const collected = [];

  function visit(currentDir) {
    const entries = fs.readdirSync(currentDir, { withFileTypes: true });

    for (const entry of entries) {
      if (IGNORED_ENTRY_NAMES.has(entry.name)) {
        continue;
      }

      if (entry.isDirectory() && entry.name === 'dist') {
        continue;
      }

      const absolutePath = path.join(currentDir, entry.name);
      if (entry.isDirectory()) {
        visit(absolutePath);
        continue;
      }

      if (!entry.isFile()) {
        continue;
      }

      collected.push(path.relative(packageRoot, absolutePath));
    }
  }

  visit(packageDir);
  collected.sort();
  return collected;
}

async function createReleaseArchive(watchface) {
  ensureValidRevision(watchface);
  const releaseEntry = getReleaseEntryForVersion(watchface);

  const outputDir = getReleaseOutputDir(watchface);
  fs.mkdirSync(outputDir, { recursive: true });

  const files = collectPackageFiles(watchface.packageDir);
  if (files.length === 0) {
    throw new Error(`No files found to package in ${watchface.packageDir}.`);
  }

  const outputName = `${getReleaseBaseName(watchface)}.zip`;
  const outputPath = path.join(outputDir, outputName);

  await runCommand('zip', ['-q', outputPath, ...files], {
    cwd: path.dirname(watchface.packageDir),
    stdio: 'inherit'
  });

  const releaseBodyPath = path.join(outputDir, `${getReleaseBaseName(watchface)}.release.md`);
  const releaseBody = createReleaseBody(watchface, releaseEntry);
  fs.writeFileSync(releaseBodyPath, releaseBody);

  const tagCommands = createGitTagCommands(watchface);
  const metadataPath = path.join(outputDir, `${getReleaseBaseName(watchface)}.release.json`);
  const metadata = {
    generatedAt: new Date().toISOString(),
    generatedAtLocalStamp: createTimestamp(),
    slug: watchface.slug,
    appId: watchface.appId,
    appName: watchface.appName,
    versionName: watchface.versionName,
    versionCode: watchface.versionCode,
    packageDir: path.relative(REPO_ROOT, watchface.packageDir),
    releaseNotesPath: path.relative(REPO_ROOT, releaseEntry.notesPath),
    artifactPath: path.relative(REPO_ROOT, outputPath),
    releaseBodyPath: path.relative(REPO_ROOT, releaseBodyPath),
    github: {
      tag: getSuggestedTagName(watchface),
      title: getSuggestedReleaseTitle(watchface)
    },
    git: {
      commands: tagCommands
    }
  };
  fs.writeFileSync(metadataPath, `${JSON.stringify(metadata, null, 2)}\n`);

  return {
    watchface,
    outputPath,
    releaseBodyPath,
    metadataPath,
    tagCommands,
    fileCount: files.length
  };
}

async function runPreview(watchface) {
  console.log(`Starting preview for ${formatWatchface(watchface)}...`);
  await runCommand('zeus', ['preview'], {
    cwd: watchface.packageDir,
    stdio: 'inherit'
  });
}

async function runRelease(watchfaces) {
  const results = [];

  for (const watchface of watchfaces) {
    console.log(`Packaging ${formatWatchface(watchface)}...`);
    const result = await createReleaseArchive(watchface);
    results.push(result);
  }

  console.log('\nCreated release artifacts:');
  for (const result of results) {
    console.log(`- ${result.outputPath} (${result.fileCount} files)`);
    console.log(`  tag: ${getSuggestedTagName(result.watchface)}`);
    console.log(`  title: ${getSuggestedReleaseTitle(result.watchface)}`);
    console.log(`  release body: ${result.releaseBodyPath}`);
    console.log(`  metadata: ${result.metadataPath}`);
    console.log('  git:');
    for (const command of result.tagCommands) {
      console.log(`    ${command}`);
    }
  }
}

async function runBump(watchface, options = {}) {
  const previousVersion = watchface.versionName;
  const nextVersion = getNextVersion(watchface, options);
  const modeLabel =
    nextVersion.mode === 'new_upstream'
      ? 'new upstream baseline'
      : nextVersion.mode === 'baseline_import'
        ? 'first local revision from imported upstream baseline'
        : 'next local revision';

  updateAppJsonVersion(watchface, nextVersion);
  const releaseNotesPath = addReleaseNotesEntry(watchface, nextVersion.versionName);
  syncReadmeForWatchface(watchface);

  console.log(`Bumped ${watchface.appName}:`);
  console.log(`- previous: ${previousVersion}`);
  console.log(`- current: ${nextVersion.versionName}`);
  console.log(`- code: ${nextVersion.versionCode}`);
  console.log(`- mode: ${modeLabel}`);
  console.log(`- app.json: ${watchface.appJsonPath}`);
  console.log(`- release notes: ${releaseNotesPath}`);
  console.log(`- readme: ${README_PATH}`);
  console.log('');
  console.log('Next steps:');
  console.log(`- Replace the TODO entry in ${releaseNotesPath}.`);
  console.log(`- Review ${README_PATH} for the updated version history block.`);
  console.log(`- Run ./watchface release --watchface ${watchface.slug} when the release notes are ready.`);
}

async function runSyncReadme(watchfaces) {
  for (const watchface of watchfaces) {
    syncReadmeForWatchface(watchface);
    console.log(`Synced README for ${watchface.appName} (${watchface.slug}).`);
  }

  console.log(`README refreshed from release notes: ${README_PATH}`);
}

async function main() {
  const args = parseArgs(process.argv.slice(2));

  if (args.help || args.command === 'help') {
    printHelp();
    return;
  }

  const watchfaces = discoverWatchfaces();
  if (watchfaces.length === 0) {
    throw new Error('No watchfaces were discovered in this repository.');
  }

  if (args.command === 'list') {
    watchfaces.forEach((watchface) => {
      console.log(formatWatchface(watchface));
    });
    return;
  }

  if (args.command === 'preview') {
    if (args.all) {
      throw new Error('Preview supports one watchface at a time. Remove --all and choose a single watchface.');
    }

    const [watchface] = await chooseWatchfaces(watchfaces, {
      selector: args.selector,
      allowAll: false,
      all: false
    });
    await runPreview(watchface);
    return;
  }

  if (args.command === 'bump') {
    if (args.all) {
      throw new Error('Bump supports one watchface at a time. Remove --all and choose a single watchface.');
    }

    const [watchface] = await chooseWatchfaces(watchfaces, {
      selector: args.selector,
      allowAll: false,
      all: false
    });
    await runBump(watchface, {
      upstreamName: args.upstreamName,
      upstreamCode: args.upstreamCode
    });
    return;
  }

  if (args.command === 'release') {
    const selected = await chooseWatchfaces(watchfaces, {
      selector: args.selector,
      allowAll: true,
      all: args.all
    });
    await runRelease(selected);
    return;
  }

  if (args.command === 'sync-readme') {
    const selected = await chooseWatchfaces(watchfaces, {
      selector: args.selector,
      allowAll: true,
      all: args.all
    });
    await runSyncReadme(selected);
    return;
  }

  throw new Error(`Unknown command: ${args.command}`);
}

main().catch((error) => {
  console.error(`Error: ${error.message}`);
  process.exitCode = 1;
});
